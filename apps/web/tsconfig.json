{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*" : ["./*"]
    },
    "jsx": "preserve",
    "strictNullChecks": false,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts",
    "../frontend/app/src/components/DashboardLeftButtons/RedBtn"
, "../frontend/app/Providers.tsx"  ],
  "exclude": [
    "node_modules"
  ],
}
